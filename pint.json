{
  "preset": "psr12",
  "rules": {
    "concat_space": {
      "spacing": "one"
    },
    "ordered_imports": {
      "sort_algorithm": "alpha"
    },
    "no_unused_imports": true,
    "single_quote": true,
    "array_syntax": {
      "syntax": "short"
    },
    "exclude": [
      "vendor",
      "storage"
    ]
  }
}