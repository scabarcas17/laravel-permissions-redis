{
    "name": "scabarcas/laravel-permissions-redis",
    "description": "A Redis-powered roles and permissions package for Laravel designed to eliminate repetitive database queries and deliver high-performance authorization.",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/redis": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/auth": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3",
        "laravel/pint": "1.29.1",
        "laravel/framework": "^12.0|^13.0",
        "orchestra/testbench": "^10.11|^11.0",
        "predis/predis": "^3.4"
    },
    "license": "MIT",
    "keywords": ["laravel", "permissions", "roles", "redis", "authorization", "acl", "rbac", "access-control", "guard", "middleware", "cache", "performance"],
    "autoload": {
        "psr-4": {
            "Scabarcas\\LaravelPermissionsRedis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scabarcas\\LaravelPermissionsRedis\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sebastian Cabarcas",
            "email": "sebastianberrio45@hotmail.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=80",
        "format": "pint",
        "analyse": "phpstan analyse",
        "mutate": "infection --threads=4 --show-mutations"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Scabarcas\\LaravelPermissionsRedis\\PermissionsRedisServiceProvider"
            ]
        }
    }
}
